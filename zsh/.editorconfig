root = true

# Default settings for all files
[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

# Markdown files (preserve trailing spaces for line breaks)
[*.md]
trim_trailing_whitespace = false

# Shell scripts
[*.{sh,bash,zsh}]
indent_size = 4

# Config files
[*.{yml,yaml,toml,json}]
indent_size = 2

# Makefiles require tabs
[Makefile]
indent_style = tab
